# Groq API key — get a free one at https://console.groq.com/keys
# Copy this file to ".env" and paste your key below. Never commit your real .env file.
#
# Reframe works without a key (it falls back to a simpler offline mode), but the
# full AI-guided reframe needs a Groq key.
VITE_GROQ_API_KEY=your_groq_api_key_here
